<!DOCTYPE html>
<html lang="zh">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>🐷 小猪跑酷</title>
  <style>
    body {
      margin: 0;
      text-align: center;
      font-family: Arial;
      background: linear-gradient(#87ceeb, #90ee90);
    }
    #game {
      position: relative;
      width: 300px;
      height: 500px;
      margin: 20px auto;
      background: #ccc;
      overflow: hidden;
      border: 4px solid #333;
      border-radius: 10px;
    }
    .pig, .item, .obstacle {
      position: absolute;
      transform: translateX(-50%);
      font-size: 30px;
    }
    .pig {
      bottom: 10px;
      transition: left 0.2s;
    }
  </style>
</head>
<body>
  <h2>🐷 小猪跑酷</h2>
  <p>得分：<span id="score">0</span></p>
  <div id="game"></div>
  <p id="gameOver" style="display:none; font-weight:bold;"></p>

  <script>
    const game = document.getElementById("game");
    const scoreEl = document.getElementById("score");
    const gameOverEl = document.getElementById("gameOver");

    let lane = 1;
    let score = 0;
    let jumping = false;
    let gameOver = false;

    const lanes = ["20%", "50%", "80%"];

    const pig = document.createElement("div");
    pig.className = "pig";
    pig.innerHTML = "🐷";
    pig.style.left = lanes[lane];
    game.appendChild(pig);

    let items = [];
    let obstacles = [];

    function spawnItem() {
      const el = document.createElement("div");
      el.className = "item";
      el.innerHTML = "🍍";
      el.dataset.lane = Math.floor(Math.random() * 3);
      el.style.left = lanes[el.dataset.lane];
      el.style.top = "0%";
      game.appendChild(el);
      items.push(el);
    }

    function spawnObstacle() {
      const el = document.createElement("div");
      el.className = "obstacle";
      el.innerHTML = "💩";
      el.dataset.lane = Math.floor(Math.random() * 3);
      el.style.left = lanes[el.dataset.lane];
      el.style.top = "0%";
      game.appendChild(el);
      obstacles.push(el);
    }

    function update() {
      if (gameOver) return;

      items.forEach((el, i) => {
        let y = parseFloat(el.style.top);
        y += 2;
        el.style.top = y + "%";

        if (y > 90) {
          if (parseInt(el.dataset.lane) === lane) {
            score++;
            scoreEl.innerText = score;
          }
          el.remove();
          items.splice(i, 1);
        }
      });

      obstacles.forEach((el, i) => {
        let y = parseFloat(el.style.top);
        y += 2;
        el.style.top = y + "%";

        if (y > 85) {
          if (parseInt(el.dataset.lane) === lane && !jumping) {
            endGame();
          }
          el.remove();
          obstacles.splice(i, 1);
        }
      });
    }

    function endGame() {
      gameOver = true;
      gameOverEl.style.display = "block";
      gameOverEl.innerText = "💀 游戏结束，得分：" + score;
    }

    // 手势控制
    let startX = 0, startY = 0;

    game.addEventListener("touchstart", e => {
      startX = e.touches[0].clientX;
      startY = e.touches[0].clientY;
    });

    game.addEventListener("touchend", e => {
      const dx = e.changedTouches[0].clientX - startX;
      const dy = e.changedTouches[0].clientY - startY;

      if (Math.abs(dx) > Math.abs(dy)) {
        if (dx > 30) lane = Math.min(2, lane + 1);
        if (dx < -30) lane = Math.max(0, lane - 1);
      } else {
        if (dy < -30 && !jumping) {
          jumping = true;
          pig.style.bottom = "120px";
          setTimeout(() => {
            jumping = false;
            pig.style.bottom = "10px";
          }, 500);
        }
      }
      pig.style.left = lanes[lane];
    });

    setInterval(spawnItem, 800);
    setInterval(spawnObstacle, 1200);
    setInterval(update, 30);
  </script>
</body>
</html>
